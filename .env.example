# ============================================================
# Checklist Boa Vista II — Variáveis de ambiente
# Copie este arquivo para ".env.local" (desenvolvimento) e
# configure as MESMAS variáveis no painel da Vercel em produção
# (Project Settings > Environment Variables).
# NUNCA cometa o arquivo .env.local real no Git.
# ============================================================

# ── Supabase ─────────────────────────────────────────────────
# Onde achar: supabase.com > seu projeto > Project Settings > API
#
# NEXT_PUBLIC_SUPABASE_URL  = "Project URL"
# NEXT_PUBLIC_SUPABASE_ANON_KEY = "anon public" key (segura para expor ao navegador)
# SUPABASE_SERVICE_ROLE_KEY = "service_role" key (NUNCA exponha esta — só em rotas server-side)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SUPABASE_SERVICE_ROLE_KEY=eyJxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Resend (envio de e-mails) ─────────────────────────────────
# Crie uma conta gratuita em resend.com (3.000 e-mails/mês grátis).
# Gere uma API Key em Resend > API Keys > Create API Key.
# Para usar um e-mail "de" personalizado (ex: checklist@suaclinica.com.br)
# você precisa verificar um domínio em Resend > Domains. Para começar
# sem isso, deixe RESEND_FROM_EMAIL como está (domínio de testes).
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=Checklist Boa Vista II <onboarding@resend.dev>
# Opcional para testes do Resend sem domínio verificado. Entrega o e-mail
# neste endereço, mas mantém o Magic Link vinculado ao usuário solicitado.
MAGIC_LINK_DELIVERY_OVERRIDE=

# ── Cron job (lembretes semanais) ─────────────────────────────
# String aleatória que protege o endpoint do cron contra chamadas
# externas não autorizadas. Gere uma com: openssl rand -base64 32
# A Vercel envia automaticamente esse valor no header Authorization
# quando você configura esta mesma variável no painel do projeto —
# não é preciso nenhuma configuração extra além de definir a env var.
CRON_SECRET=troque-isso-por-uma-string-aleatoria-longa

# ── App ──────────────────────────────────────────────────────
# URL pública do site (usada nos links dentro dos e-mails)
NEXT_PUBLIC_APP_URL=http://localhost:3000
